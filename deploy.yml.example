# GitHub Actions 로 Pages 자동 배포를 원하면 이 파일을
#   .github/workflows/deploy.yml  로 옮기고 push 하세요.
# (workflow 파일 push 에는 토큰의 'workflow' 스코프가 필요합니다)
# 그 후 저장소 Settings → Pages → Source: GitHub Actions 로 설정.
name: Deploy to GitHub Pages

on:
  push:
    branches: [main]
  workflow_dispatch:

permissions:
  contents: read
  pages: write
  id-token: write

concurrency:
  group: pages
  cancel-in-progress: true

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: 20
          cache: npm
      - run: npm ci
      # 저장소 이름을 base 로 사용 (예: /my-repo/)
      - run: VITE_BASE="/${GITHUB_REPOSITORY#*/}/" npm run build
      - uses: actions/upload-pages-artifact@v3
        with:
          path: dist

  deploy:
    needs: build
    runs-on: ubuntu-latest
    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}
    steps:
      - id: deployment
        uses: actions/deploy-pages@v4
